      "rangeLength": 0,
      "text": "void ButtonInterruptHandler(void *CallbackRef) {\n    xil_printf(\"Button Interrupt Triggered\\n\"); //Mesaj Debug\n    // Convertim CallbackRef la pointer de tip XGpio\n    XGpio *GpioPtr = (XGpio *)CallbackRef;\n    uint32_t btn_value;\n    // Citește starea butoanelor folosind pointerul la GPIO din\n    //CallbackRef\n    btn_value = XGpio_DiscreteRead(GpioPtr, 1);\n    // Verifică care buton a fost apăsat și incrementează\n    //contorul corespunzător\n    if (btn_value & 0x1) {\n        counter_btn1++;//daca butonul 1 e apasat incrementeaza counterul 1\n    } else if (btn_value & 0x2) {\n        counter_btn2++;//daca butonul 2 e apasat incrementeaza counterul 2\n    }\n    else if (btn_value & 0x4) {\n        //daca butonul 3 e apasat va trebui sa executam inmultirea\n        //Resetam procesul de inmultire (daca cumva se apasa de mai\n        //multe ori pe acelasi buton. Furnizam operanzii care sunt valorile\n        //de la cele 2 countere\n        XGpio_DiscreteWrite(&inputRst, 1, 0);\n        XGpio_DiscreteWrite(&inputA, 1, counter_btn1);\n        XGpio_DiscreteWrite(&inputB, 1, counter_btn2);\n        //in cele din urma setam bitul de start pe 1 pentru a declansa\n        //inmultirea\n        XGpio_DiscreteWrite(&startMultiplication, 1, 1);\n    }\n    // Șterge întreruperea pentru butoane folosind pointerul la GPIO din CallbackRef\n    XGpio_InterruptClear(GpioPtr, 1);\n    }",
      "rangeOffset": 4890,
      "forceMoveMarkers": false
    }
  ],
