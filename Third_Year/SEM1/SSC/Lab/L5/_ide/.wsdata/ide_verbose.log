      "text": "/ În funcție de switch-ul activ, afișăm contorul corespunzător\nif (switch_data & 0x1) {\nled_value = counter_btn1;\n// Dacă primul switch este activ, afișăm contorul pentru primul buton\nprintf(\"Valoarea primului operand e NaN\\n\", counter_btn1);\n} else if (switch_data & 0x2) {\nled_value = counter_btn2;\n// Dacă al doilea switch este activ, afișăm contorul pentru al\n//doilea buton\nprintf(\"Valoarea celui de-al doilea operand e %d\\n\",\ncounter_btn2);\n} else if (switch_data & 0x4) {\n// Dacă al treilea switch este activ, afișăm rezultatul multiplicării\nprintf(\"Rezultatul inmultirii e %d\\n\", rez);\n}\nelse {\nled_value = 0; // Dacă niciun switch nu este activ, afișăm 0\n}\n// Afișează valoarea pe LED-uri\nXGpio_DiscreteWrite(&outputLed, 1, led_value);\n}\n// Handler pentru întreruperea semnalului \"gata\" (finalizarea\n//multiplicării)\nvoid SignalGataIntreruptHandler(void *CallbackRef){\nXGpio *GpioPtr = (XGpio *)CallbackRef;\n// Citește rezultatul multiplicării de la modulul VHDL\nrez = XGpio_DiscreteRead(&outputMul, 1);\nprintf(\"Dupa inmultire avem %d\\n\", rez); // Afișează rezultatul\n// Resetăm semnalul de start și resetează intrările\nXGpio_DiscreteWrite(&startMultiplication, 1, 0);\nXGpio_DiscreteWrite(&inputRst, 1, 1);\nXGpio_InterruptClear(GpioPtr, 1); // Șterge întreruperea\n}\nvoid ButtonInterruptHandler(void *CallbackRef) {\nxil_printf(\"Button Interrupt Triggered\\n\"); //Mesaj Debug\n// Convertim CallbackRef la pointer de tip XGpio\nXGpio *GpioPtr = (XGpio *)CallbackRef;\nuint32_t btn_value;\n// Citește starea butoanelor folosind pointerul la GPIO din\n//CallbackRef\nbtn_value = XGpio_DiscreteRead(GpioPtr, 1);\n// Verifică care buton a fost apăsat și incrementează\n//contorul corespunzător\nif (btn_value & 0x1) {\ncounter_btn1++;//daca butonul 1 e apasat incrementeaza counterul 1\n} else if (btn_value & 0x2) {\ncounter_btn2++;//daca butonul 2 e apasat incrementeaza counterul 2\n}",
