      },
      "rangeLength": 0,
      "text": "//8.Conectează handlerul pentru semnalul gata la întrerupere\n//(semnalul \"gata\" din multiplicatorul hardware)\n// Conectează întreruperea `INTC_INTERRUPT_MUL_ID` la funcția\n//`SignalGataIntreruptHandler`, care va fi apelată\n// când semnalul de ieșire \"gata\" al multiplicatorului devine activ.\nXScuGic_Connect(IntcInstancePtr, INTC_INTERRUPT_MUL_ID,\n(Xil_ExceptionHandler)SignalGataIntreruptHandler,\n(void *)GpioMulPtr2);\n//9.Setează prioritatea și tipul de trigger\n// Configurează prioritatea și tipul de declanșare (edge/level)\n//pentru întreruperile înregistrate. // `0x00` setează prioritate\n//maximă (cea mai mare urgență), iar `0x3` specifică tipul de\n//declanșare.\nXScuGic_SetPriorityTriggerType(IntcInstancePtr,\nINTC_INTERRUPT_ID, 0x00, 0x3);\nXScuGic_SetPriorityTriggerType(IntcInstancePtr,\nINTC_INTERRUPT_MUL_ID, 0x00, 0x3);\n//10.Activează întreruperea pentru butoane în controller-ul de\n//întreruperi. Activează întreruperile locale și globale pentru\n//butoanele gestionate prin GPIO.\nXGpio_InterruptEnable(GpioInstancePtr, 1);\nXGpio_InterruptGlobalEnable(GpioInstancePtr);\n//11.Activează întreruperea pentru semnalul \"gata\" (multiplicator) în\n//controller-ul de întreruperi GPIO\n// Activează întreruperile locale și globale pentru semnalul \"gata\"\nde la multiplicator.\nXGpio_InterruptEnable(GpioMulPtr2, 1);\nXGpio_InterruptGlobalEnable(GpioMulPtr2);\n//12.Activează întreruperile în controller-ul de întreruperi general\nXScuGic_Enable(IntcInstancePtr, INTC_INTERRUPT_ID);\nXScuGic_Enable(IntcInstancePtr, INTC_INTERRUPT_MUL_ID);\n// 13. Dacă toate etapele au fost realizate cu succes, returnează\nXST_SUCCESS\nreturn XST_SUCCESS;\n}",
      "rangeOffset": 7126,
      "forceMoveMarkers": false
    }
  ],
