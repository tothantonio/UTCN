      "text": "#include <stdint.h>\n#include <stdio.h>\n#include \"platform.h\"\n#include \"xil_printf.h\"\n#include \"xparameters.h\"\n#include \"xgpio.h\"\n#include \"xscugic.h\"\n#include \"xil_exception.h\"\n// Definim ID-uri pentru întreruperi (multiplicare și butoane)\n#define INTC_INTERRUPT_MUL_ID 61\n#define INTC_INTERRUPT_ID 62\n// Variabile pentru a stoca valorile numaratoarelor\nvolatile u32 counter_btn1 = 0;\nvolatile u32 counter_btn2 = 0\nvolatile u32 rez; // stocheaza rezultatul multiplicării\n// Instanțiem obiectele pentru controlul GPIO și al întreruperilor\n// Obiecte pentru butoane, switch-uri și LED-uri\nXGpio inputButon, inputSwitch, outputLed;\nXScuGic Intc;// Instanță a controlerului de întreruperi\n// Definim GPIO pentru intrările/ieșirile aferente modulului VHDL\nXGpio startMultiplication,inputRst, inputA, inputB, outputMul,\noutputGata;\n// Protocoale functii\n// Funcție handler pentru întreruperile de la butoane\nvoid ButtonInterruptHandler(void *CallbackRef);\n// Handler pentru semnalul \"gata\" (finalizarea multiplicării)\nvoid SignalGataIntreruptHandler(void *CallbackRef);\n// Funcție pentru configurarea întreruperilor\nint SetupInterruptSystem(XScuGic *IntcInstancePtr, XGpio\n*GpioInstancePtr, XGpio *GpioMulPtr2);",
