      "rangeLength": 8,
      "text": "for (uint32_t i = 0; i + 8 <= pixels; i += 8) {\nconst uint8_t *p = src + i*3;\n// Încarcă 8 pixeli R, G, B intercalat din memorie\nuint8x8x3_t rgb = vld3_u8(p);\n//Convertim fiecare canal de la 8 biți → 16 biți\n// pentru a putea înmulți fără overflow\nuint16x8_t r16 = vmovl_u8(rgb.val[0]);\nuint16x8_t g16 = vmovl_u8(rgb.val[1]);\nuint16x8_t b16 = vmovl_u8(rgb.val[2]);\nuint16x8_t sum =\nvaddq_u16(vaddq_u16(vmulq_n_u16(r16,77),\nvmulq_n_u16(g16,150)), vmulq_n_u16(b16,29));\n// Împărțim la 256 (>>8) și convertim u16 → u8\nuint8x8_t gray = vshrn_n_u16(sum, 8);\nuint8x8x3_t out;\nout.val[0] = gray;\nout.val[1] = gray;\nout.val[2] = gray;\n//Scriem 8 pixeli grayscale (3 canale) în memorie\nvst3_u8(dst + i*3, out);\n}\nfor (; i < pixels; i++) {\nconst uint8_t *p = src + i*3;\nuint8_t gray = (77*p[0] + 150*p[1] + 29*p[2]) >> 8;\ndst[i*3 + 0] = gray; dst[i*3 + 1] = gray;\ndst[i*3 + 2] = gray;\n}",
      "rangeOffset": 15135,
      "forceMoveMarkers": false
    }
  ],
